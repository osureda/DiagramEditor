{

	"diagramGroups": {

		"er": {
			"icon": ":/images/erDiagram.png",
			"name": "E/R",
			"description": "Models entities, attributes, and relationships\nto design the conceptual structure of a database.",
			"diagrams": [
				"entrel",
				"entrelSimplified"
			]
		},

		"uml": {
			"icon": ":/images/umlDiagram.png",
			"name": "UML",
			"description": "Models the structure, behavior, and interactions\nof a system using standardized visual diagrams.",
			"diagrams": [
				"classes",
				"objects",
				"deployment"
			]
		}

	},

	"diagramTypes": {

		"entrel": {
			"icon": ":/images/entityRelationship.png",
			"name": "Entity-relationship diagram",
			"description": "Visually defines the main data elements of a system through entities, attributes, keys, and\nrelationships. Recommended for the conceptual design of databases.",
			"items": {
				"Entities": [
					"entity",
					"weakEntity",
					"associativeEntity",
					"note"
				],
				"Attributes": [
					"attribute",
					"keyAttribute",
					"weakKeyAttribute",
					"multivaluedAttribute",
					"derivedAttribute"
				],
				"Relationships": [
					"relationship",
					"identifyingRelationship",
					"participation"
				]
			}
		},

		"entrelSimplified": {
			"icon": ":/images/simplifiedEntityRelationship.png",
			"name": "Simplified Entity-relationship diagram",
			"description": "Models basic entities and relationships to represent the core data structure of a system in a\nsimple and intuitive way.",
			"items": {
				"Entity": [
					"entity"
				],
				"Relationship": [
					"relationship"
				]
			}
		},

		"classes": {
			"icon": ":/images/classesDiagram.png",
			"name": "Class diagram",
			"description": "Visually defines the static structure of a system through classes, attributes, operations, inheritance,\nassociations, and dependencies. Recommended for designing object-oriented software models.",
			"items": {
				"Objects": [
					"class",
					"enumeration",
					"typedClass",
					"associationClass",
					"note"
				],
				"Relationships": [
					"association",
					"generalization",
					"dependency",
					"typedDependency"
				]
			}
		},

		"objects": {
			"icon": ":/images/objectsDiagram.png",
			"name": "Object diagram",
			"description": "Visually represents instances of classes, their attribute values, and the links between them at a particular\npoint in time. Recommendedfor illustrating concrete examples of a class model or validating the structure\nof an object-oriented system.",
			"items": {
				"Class": [
					"class"
				],
				"Association": [
					"association"
				]
			}
		},

		"deployment": {
			"icon": ":/images/deploymentDiagram.png",
			"name": "Deployment diagram",
			"description": "Visually represents how software components or artifacts are distributedacross hardware devices,\nservers, execution environments, and network connections. Recommended for documenting the\nphysical architecture and deployment infrastructure of a system.",
			"items": {
				"Note": [
					"note"
				]
			}
		}

	},

